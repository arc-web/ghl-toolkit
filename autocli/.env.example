# GoHighLevel API Key (from the 'a' cookie, base64-decoded → apiKey field)
GHL_API_KEY=

# Firebase API Key (legacy — only needed if not using v2 JWT refresh)
GHL_FIREBASE_API_KEY=AIzaSyB_w3vXmsI7WeQtrIOkjR6xTRVN5uOieiE

# Firebase Refresh Token (legacy — deprecated in favor of v2 JWT)
GHL_FIREBASE_REFRESH_TOKEN=

# v2 JWT Auth Token (1-hour lifetime, auto-refreshed)
# Get via: node skills/ghl-auth/scripts/ghl-bootstrap.mjs
GHL_AUTH_TOKEN=

# v2 JWT Refresh Token (30-day lifetime, rotates on each use)
# CRITICAL: This is the primary auth mechanism. Auto-rotates.
GHL_REFRESH_TOKEN=

# Your GHL Location ID (found in the URL: app.gohighlevel.com/v2/location/THIS_ID/...)
GHL_LOCATION_ID=

# Second location (optional)
GHL_LOCATION_ID_2=

# Your GHL User ID (from the 'a' cookie, base64-decoded → userId field)
GHL_USER_ID=

# Your GHL Company ID (from the 'a' cookie, base64-decoded → companyId field)
GHL_COMPANY_ID=
